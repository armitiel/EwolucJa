# Ewolucja — Konfiguracja backendu
# Skopiuj ten plik do .env i uzupełnij wartości.

# Klucz API Anthropic (Claude) — wymagany do pełnej funkcjonalności agentów AI
# Bez klucza agenci działają w trybie demo (fallback z gotowymi odpowiedziami)
ANTHROPIC_API_KEY=sk-ant-xxx

# Port serwera (domyślnie 3001)
PORT=3001
